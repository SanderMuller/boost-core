{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "github": {
            "type": "object",
            "properties": {
                "default_base_branch": { "type": "string", "default": "main" }
            }
        },
        "testing": {
            "type": "object",
            "properties": {
                "backend_framework": { "type": "string" },
                "forbid": { "type": "array" }
            }
        },
        "codex": {
            "type": "object",
            "properties": {
                "invocation_mode": { "type": "string", "default": "plugin" }
            }
        },
        "mcp": {
            "type": "object",
            "properties": {
                "jira": { "type": "string", "default": "mcp-atlassian" }
            }
        },
        "branches": {
            "type": "object",
            "properties": {
                "patterns": { "type": "array", "render": ["bullets", "yaml"] }
            }
        }
    }
}
