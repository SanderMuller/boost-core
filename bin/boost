#!/usr/bin/env php
<?php declare(strict_types=1);

use SanderMuller\BoostCore\Commands\CommandRegistry;
use Symfony\Component\Console\Application;

(function (): void {
    // Order matters. In a Composer dist install (`vendor/sandermuller/boost-core/bin/boost`),
    // the project's top-level autoload at `../../../autoload.php` is what we want — it has
    // the consuming project's installed.php and dep graph.
    //
    // In a dev install (running boost-core's own tests from its root), there is no
    // `../../../autoload.php` and `__DIR__ . '/../vendor/autoload.php'` IS the project
    // autoload — fall-through works.
    //
    // The order was previously inverted, which broke path-repo dev installs: boost-core's
    // nested `vendor/sandermuller/boost-core/vendor/autoload.php` won over the project
    // top-level autoload, so InstalledVersions returned paths into the nested vendor dir
    // (where `resources/boost/conventions-schema.json` and similar resources don't exist)
    // and SchemaDiscovery silently skipped every vendor.
    $autoloadCandidates = [
        __DIR__ . '/../../../autoload.php',
        __DIR__ . '/../vendor/autoload.php',
    ];

    foreach ($autoloadCandidates as $candidate) {
        if (file_exists($candidate)) {
            require $candidate;
            break;
        }
    }

    $app = new Application('boost', '0.1.0-dev');

    $commands = [];
    foreach (CommandRegistry::commands() as $command) {
        $name = $command->getName();
        if (is_string($name) && str_starts_with($name, 'boost:')) {
            $command->setName(substr($name, strlen('boost:')));
        }
        $commands[] = $command;
    }

    // addCommands() is stable across symfony/console ^7.0||^8.0; the
    // per-command add() it replaced was removed in Symfony 8.
    $app->addCommands($commands);

    $app->run();
})();
