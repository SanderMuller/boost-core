#!/usr/bin/env php
<?php

declare(strict_types=1);

(function (): void {
    $autoloadCandidates = [
        __DIR__ . '/../vendor/autoload.php',
        __DIR__ . '/../../../autoload.php',
    ];

    foreach ($autoloadCandidates as $candidate) {
        if (file_exists($candidate)) {
            require $candidate;
            break;
        }
    }

    $app = new \Symfony\Component\Console\Application('boost', '0.1.0-dev');

    foreach ((new \SanderMuller\BoostCore\BoostCoreCommandProvider())->getCommands() as $command) {
        $name = $command->getName();
        if (is_string($name) && str_starts_with($name, 'boost:')) {
            $command->setName(substr($name, strlen('boost:')));
        }
        $app->add($command);
    }

    $app->run();
})();
